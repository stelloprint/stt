#!/usr/bin/env sh

if [ "$LEFTHOOK" = "0" ] || [ "$LEFTHOOK" = "false" ]; then
  exit 0
fi

find_lefthook_bin() {
  if [ -n "$LEFTHOOK_BIN" ] && [ -x "$LEFTHOOK_BIN" ]; then
    printf '%s\n' "$LEFTHOOK_BIN"
    return 0
  fi

  if command -v lefthook >/dev/null 2>&1; then
    bin=$(command -v lefthook)
    case "$bin" in
      */node_modules/.bin/lefthook) ;;
      */node_modules/lefthook/bin/index.js) ;;
      *)
        printf '%s\n' "$bin"
        return 0
        ;;
    esac
  fi

  dir=$(git rev-parse --show-toplevel 2>/dev/null) || return 1
  common_dir=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null || git rev-parse --git-common-dir 2>/dev/null)
  common_root=
  if [ -n "$common_dir" ]; then
    case "$common_dir" in
      /*) common_root=$(dirname "$common_dir") ;;
      *) common_root=$(dirname "$dir/$common_dir") ;;
    esac
  fi
  os_arch=$(uname | tr '[:upper:]' '[:lower:]')
  cpu_arch=$(uname -m | sed 's/aarch64/arm64/;s/x86_64/x64/')

  for search_root in "$dir" "$common_root"
  do
    [ -n "$search_root" ] || continue

    for candidate in \
      "$search_root/node_modules/lefthook-${os_arch}-${cpu_arch}/bin/lefthook" \
      "$search_root/node_modules/@evilmartians/lefthook/bin/lefthook-${os_arch}-${cpu_arch}/lefthook" \
      "$search_root/node_modules/@evilmartians/lefthook-installer/bin/lefthook"
    do
      if [ -x "$candidate" ]; then
        printf '%s\n' "$candidate"
        return 0
      fi
    done

    for candidate in "$search_root"/node_modules/.bun/lefthook-"${os_arch}"-"${cpu_arch}"@*/node_modules/lefthook-"${os_arch}"-"${cpu_arch}"/bin/lefthook
    do
      if [ -x "$candidate" ]; then
        printf '%s\n' "$candidate"
        return 0
      fi
    done
  done

  return 1
}

lefthook_bin=$(find_lefthook_bin)
if [ -z "$lefthook_bin" ]; then
  echo "Can't find a native lefthook binary in PATH or node_modules" >&2
  echo "Install dependencies or set LEFTHOOK_BIN to the native executable" >&2
  exit 1
fi

exec "$lefthook_bin" run pre-commit "$@"
